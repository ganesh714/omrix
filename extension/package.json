{
  "name": "omrix",
  "displayName": "Omrix Chat",
  "description": "Omrix AI Chatbot",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySideBar": [
        {
          "id": "omrix-sidebar",
          "title": "Omrix",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "omrix-sidebar": [
        {
          "type": "webview",
          "id": "omrix.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^5.3.3"
  }
}
